# Notion API credentials
# Copy this file to .env and fill in your values.
# Never commit .env — it contains your secret token.

# 1. Go to https://www.notion.so/my-integrations
# 2. Create a new integration (Internal), give it read+write content access.
# 3. Copy the "Internal Integration Secret" token below.
NOTION_TOKEN=secret_your_token_here

# 1. Open the Notion page you want as the parent for all synced content.
# 2. Click "Share" → "Copy link". The page ID is the 32-char hex at the end
#    of the URL (with or without hyphens), e.g.:
#    https://www.notion.so/My-Page-abc123def456...  →  abc123def456...
# 3. Also make sure to share the page with your integration
#    (Share → Invite → select your integration).
NOTION_PARENT_PAGE_ID=your_page_id_here
